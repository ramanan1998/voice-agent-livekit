# Copy this file to .env.local and fill in the values.
# `lk app env` / the CLI template setup can populate the LiveKit values for you.

# --- LiveKit Cloud project credentials (required) ---
# Find these in the LiveKit Cloud dashboard under Settings -> Keys.
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your_api_key
LIVEKIT_API_SECRET=your_api_secret

# --- Pipeline mode ---
# cascade  = STT -> LLM -> TTS, keyless via LiveKit Inference.
#            Best transcripts/records + tool reliability (good for HR screening).
# realtime = single speech-to-speech model. Lower latency, more natural voice.
#            Requires OPENAI_API_KEY below (good for customer support).
MODE=cascade

# --- Outbound calling (required only for outbound) ---
# The trunk ID printed by scripts/setup_outbound_trunk.py
SIP_OUTBOUND_TRUNK_ID=

# --- Model keys ---
# Required when MODE=realtime. Not needed for MODE=cascade (uses LiveKit Inference).
# OPENAI_API_KEY=
